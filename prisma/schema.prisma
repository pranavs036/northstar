generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String       @id @default(cuid())
  name        String
  domain      String
  email       String       @unique
  supabaseId  String?      @unique
  plan        Plan         @default(FREE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  audits      Audit[]
  competitors Competitor[]
  skus        Sku[]
}

model Sku {
  id          String       @id @default(cuid())
  brandId     String
  skuCode     String
  name        String
  category    String?
  url         String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  diagnoses   Diagnosis[]
  scanResults ScanResult[]
  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, skuCode])
  @@index([brandId])
}

model Competitor {
  id      String  @id @default(cuid())
  brandId String
  domain  String
  name    String?
  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
}

model Audit {
  id          String      @id @default(cuid())
  brandId     String
  status      AuditStatus @default(PENDING)
  agentScore  Int?
  reportUrl   String?
  createdAt   DateTime    @default(now())
  completedAt DateTime?
  brand       Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  diagnoses   Diagnosis[]

  @@index([brandId])
}

model ScanResult {
  id               String   @id @default(cuid())
  skuId            String
  engine           Engine
  query            String
  brandVisible     Boolean
  competitorDomain String?
  rawResponse      String
  scannedAt        DateTime @default(now())
  sku              Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
}

model Diagnosis {
  id             String   @id @default(cuid())
  auditId        String
  skuId          String
  engine         Engine
  severity       Severity
  reason         String
  fix            String
  competitorData Json?
  brandPdpData   Json?
  createdAt      DateTime @default(now())
  audit          Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  sku            Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([skuId])
}

enum Plan {
  FREE
  AUDIT
  MAINTENANCE
}

enum AuditStatus {
  PENDING
  SCANNING
  ANALYZING
  COMPLETE
  FAILED
}

enum Engine {
  CHATGPT
  GOOGLE
  PERPLEXITY
  BING
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}
